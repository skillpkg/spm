{
  "name": "@spm/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "spm": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@spm/shared": "workspace:^",
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.0.0",
    "conf": "13",
    "inquirer": "^12.3.0",
    "open": "^10.1.0",
    "ora": "^8.1.0",
    "semver": "^7.7.4",
    "tar": "^7.5.9",
    "toml": "3"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1",
    "@types/tar": "^7.0.87",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
