#!/bin/sh
# Wrapper script — delegates to the downloaded Go binary.
# Resolve symlinks to find the real script location (npm creates symlinks for global installs).
SELF="$0"
while [ -L "$SELF" ]; do
  DIR="$(cd "$(dirname "$SELF")" && pwd)"
  SELF="$(readlink "$SELF")"
  # Handle relative symlinks
  case "$SELF" in
    /*) ;;
    *) SELF="$DIR/$SELF" ;;
  esac
done
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
BINARY="$SCRIPT_DIR/spm-go"

if [ -x "$BINARY" ]; then
  exec "$BINARY" "$@"
fi

echo "SPM binary not found. Run 'npm rebuild @skillpkg/cli' or install from:" >&2
echo "  https://github.com/skillpkg/spm/releases" >&2
exit 1
